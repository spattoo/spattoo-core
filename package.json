{
  "name": "@spattoo/designer",
  "version": "0.1.16",
  "type": "module",
  "main": "./dist/spattoo-designer.umd.cjs",
  "module": "./dist/spattoo-designer.js",
  "exports": {
    ".": {
      "import": "./dist/spattoo-designer.js",
      "require": "./dist/spattoo-designer.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "NODE_ENV=production vite build",
    "check:paths": "node scripts/check-paths.mjs",
    "check:dup": "jscpd src/designer",
    "test": "vitest run",
    "verify": "npm run check:paths && npm run check:dup && npm test"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "@supabase/supabase-js": ">=2",
    "react": ">=18",
    "react-colorful": ">=5",
    "react-dom": ">=18",
    "three": ">=0.150"
  },
  "devDependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@supabase/supabase-js": "^2.103.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jscpd": "^5.0.10",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2",
    "vite": "^6.3.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@pmndrs/assets": "^1.7.0"
  }
}
